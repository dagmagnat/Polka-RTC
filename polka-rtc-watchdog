#!/usr/bin/env bash
set -euo pipefail

CLIENT_DIR="${CLIENT_DIR:-/etc/olcrtc/clients}"
LOG_FILE="${WATCHDOG_LOG_FILE:-/var/log/polka-rtc-watchdog.log}"
STATE_DIR="${WATCHDOG_STATE_DIR:-/var/lib/polka-rtc/watchdog}"

mkdir -p "$(dirname "$LOG_FILE")" "$STATE_DIR"

log() {
  echo "[$(date '+%F %T')] $*" >> "$LOG_FILE"
}

restart_unit() {
  local unit="$1"
  systemctl reset-failed "$unit" >/dev/null 2>&1 || true
  systemctl restart "$unit" >/dev/null 2>&1 || true
  log "restart $unit"
}

should_auto_recover() {
  local client_id="$1"
  local interval_minutes="$2"
  local stamp_file="${STATE_DIR}/${client_id}.autorecovery"

  [[ "$interval_minutes" =~ ^[0-9]+$ ]] || return 1
  [[ "$interval_minutes" -gt 0 ]] || return 1

  local now
  now="$(date +%s)"

  if [[ ! -f "$stamp_file" ]]; then
    echo "$now" > "$stamp_file"
    return 1
  fi

  local last
  last="$(cat "$stamp_file" 2>/dev/null || echo 0)"
  [[ "$last" =~ ^[0-9]+$ ]] || last=0

  if (( now - last >= interval_minutes * 60 )); then
    echo "$now" > "$stamp_file"
    return 0
  fi

  return 1
}

if [[ ! -d "$CLIENT_DIR" ]]; then
  log "client dir not found: $CLIENT_DIR"
  exit 0
fi

shopt -s nullglob

for env_file in "$CLIENT_DIR"/*.env; do
  client_id="$(basename "$env_file" .env)"
  unit="olcrtc-client@${client_id}.service"

  set +u
  CARRIER=""
  TELEMOST_STABLE_MODE=""
  TELEMOST_AUTO_RECOVERY=""
  TELEMOST_AUTO_RECOVERY_INTERVAL_MINUTES=""
  # shellcheck disable=SC1090
  source "$env_file"
  set -u

  if [[ "$CARRIER" != "telemost" || "${TELEMOST_STABLE_MODE:-1}" == "0" ]]; then
    continue
  fi

  enabled="$(systemctl is-enabled "$unit" 2>/dev/null || true)"
  active="$(systemctl is-active "$unit" 2>/dev/null || true)"

  # If the device was stopped from the bot, the unit is disabled. Do not revive it.
  if [[ "$enabled" != "enabled" ]]; then
    if [[ "$active" == "failed" ]]; then
      log "$unit state=failed but enabled=$enabled -> skip"
    fi
    continue
  fi

  case "$active" in
    active|activating)
      if [[ "${TELEMOST_AUTO_RECOVERY:-0}" == "1" ]]; then
        interval="${TELEMOST_AUTO_RECOVERY_INTERVAL_MINUTES:-5}"
        if should_auto_recover "$client_id" "$interval"; then
          log "$unit auto-recovery enabled interval=${interval}m -> stable restart"
          restart_unit "$unit"
        fi
      fi
      ;;
    failed|inactive|deactivating)
      log "$unit state=$active enabled=$enabled -> restart"
      restart_unit "$unit"
      ;;
    *)
      log "$unit state=$active enabled=$enabled -> no action"
      ;;
  esac
done
